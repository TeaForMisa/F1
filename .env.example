# === ОСНОВНЫЕ НАСТРОЙКИ ===

# Получить токен у @BotFather в Telegram
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Часовой пояс по умолчанию для новых пользователей (IANA)
DEFAULT_TIMEZONE=Europe/Moscow

# Сезон Формулы-1
F1_SEASON=2026

# === ХРАНИЛИЩЕ ===

# Путь к файлу базы данных SQLite.
# На Bothost: оставь пустым или укажи /app/data/f1bot.db — папка /app/data
# персистентна и переживёт обновления из Git.
# Локально при разработке: оставь пустым (создастся f1bot.db рядом с кодом).
DB_PATH=

# === АДМИН-ПАНЕЛЬ ===

# Telegram ID администраторов через запятую.
# Узнать свой ID: напиши @userinfobot в Telegram.
# Только эти пользователи смогут использовать /stats, /users, /broadcast и т.д.
ADMIN_IDS=123456789,987654321

# === ЛИМИТЫ БЕЗОПАСНОСТИ ===

# Минимальный интервал между командами одного пользователя (секунды).
# Защищает от спама и перегрузки внешнего API.
THROTTLE_SECONDS=3

# Интервал троттлинга для нажатий инлайн-кнопок (секунды, можно дробное).
# Меньше, чем для команд, чтобы навигация по /menu была отзывчивой.
CALLBACK_THROTTLE_SECONDS=0.5

# Сколько секунд кешировать зачёты пилотов/команд в памяти.
# Снижает нагрузку на Jolpica-F1 API (по умолчанию 5 минут).
STANDINGS_CACHE_TTL=300

# Максимальная длина ввода кастомного часового пояса (символы).
MAX_TZ_INPUT_LENGTH=50

# Как часто планировщик проверяет сессии (секунд)
SCHEDULER_INTERVAL=30
